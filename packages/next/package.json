{
  "name": "@uploadkit/next",
  "version": "0.1.0",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@uploadkit/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "devDependencies": {
    "@uploadkit/config": "workspace:*",
    "tsup": "latest",
    "typescript": "latest"
  }
}
