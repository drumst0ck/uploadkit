{
  "name": "@uploadkit/shared",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@uploadkit/config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "latest",
    "vitest": "latest"
  }
}
