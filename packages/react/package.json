{
  "name": "@uploadkitdev/react",
  "version": "0.2.1",
  "description": "Premium React components for UploadKit — UploadButton, UploadDropzone, FileList with CSS variable theming and dark mode out of the box.",
  "license": "MIT",
  "author": "Drumst0ck",
  "homepage": "https://uploadkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drumst0ck/uploadkit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/drumst0ck/uploadkit/issues"
  },
  "keywords": [
    "upload",
    "file-upload",
    "react",
    "uploadkit",
    "dropzone",
    "upload-button",
    "typescript"
  ],
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.mjs",
      "require": "./dist/tailwind.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@uploadkitdev/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "motion": ">=12"
  },
  "peerDependenciesMeta": {
    "motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@uploadkitdev/config": "workspace:*",
    "@uploadkitdev/next": "workspace:*",
    "jsdom": "^29.0.2",
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "^4.1.3"
  }
}
