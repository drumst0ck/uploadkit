{
  "name": "@uploadkitdev/core",
  "version": "0.2.1",
  "description": "UploadKit core SDK — type-safe presigned URL client for browser, Node and Edge runtimes.",
  "license": "MIT",
  "author": "Drumst0ck",
  "homepage": "https://uploadkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drumst0ck/uploadkit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/drumst0ck/uploadkit/issues"
  },
  "keywords": [
    "upload",
    "file-upload",
    "uploadkit",
    "s3",
    "r2",
    "presigned-url",
    "typescript"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@uploadkitdev/shared": "workspace:*",
    "@uploadkitdev/config": "workspace:*",
    "tsup": "latest",
    "typescript": "latest"
  }
}
