{
  "name": "@uploadkit/next",
  "version": "0.1.0",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@uploadkit/core": "workspace:*",
    "@uploadkit/shared": "workspace:*",
    "@aws-sdk/client-s3": "latest",
    "@aws-sdk/s3-request-presigner": "latest",
    "nanoid": "latest",
    "server-only": "latest"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "devDependencies": {
    "@uploadkit/config": "workspace:*",
    "tsup": "latest",
    "typescript": "latest"
  }
}
