{
  "name": "uploadkit",
  "version": "0.1.0",
  "description": "Install UploadKit into an existing project — init, add, restore.",
  "license": "MIT",
  "author": "Drumst0ck",
  "homepage": "https://uploadkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drumst0ck/uploadkit.git",
    "directory": "packages/uploadkit-cli"
  },
  "bugs": {
    "url": "https://github.com/drumst0ck/uploadkit/issues"
  },
  "keywords": [
    "uploadkit",
    "cli",
    "init",
    "add",
    "upload",
    "file-upload",
    "next",
    "sveltekit",
    "remix",
    "vite"
  ],
  "type": "module",
  "bin": {
    "uploadkit": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke-matrix.ts"
  },
  "dependencies": {
    "@clack/prompts": "latest",
    "execa": "latest",
    "fast-glob": "^3.3.3",
    "magicast": "latest",
    "mri": "latest",
    "picocolors": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@uploadkitdev/config": "workspace:*",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
