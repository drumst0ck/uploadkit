# Database
MONGODB_URI=mongodb://root:password@localhost:27017/uploadkit?authSource=admin

# Redis (rate limiting — optional, falls back to in-memory if unset)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=uploadkit-dev

# CDN (production only)
CDN_URL=https://cdn.uploadkit.dev

# Cloudflare Custom Hostnames (SSL for SaaS — custom CDN domains)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=              # Zone ID for uploadkit.dev
CLOUDFLARE_CDN_FALLBACK=cdn.uploadkit.dev  # CNAME target for customer domains

# Paid UploadKit Cloud image transformations
IMAGE_TRANSFORM_BASE_URL=https://cdn.uploadkit.dev
IMAGE_TRANSFORM_SECRET=  # Generate with: openssl rand -base64 48
IMAGE_TRANSFORM_PUBLIC_SECRET=  # Separate long-lived secret; rotating it invalidates stable public URLs

# Authentication (Auth.js v5)
AUTH_SECRET=          # Generate with: npx auth secret
AUTH_GITHUB_ID=       # GitHub OAuth App -> Client ID (Settings > Developer Settings > OAuth Apps)
AUTH_GITHUB_SECRET=   # GitHub OAuth App -> Client Secret
AUTH_GOOGLE_ID=       # Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=   # Google Cloud Console -> OAuth 2.0 Client Secret
AUTH_RESEND_KEY=      # Resend Dashboard -> API Keys -> Create API Key
AUTH_URL=http://localhost:3001  # Set to https://dashboard.uploadkit.dev in production

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=    # Created by scripts/setup-stripe.ts or from Stripe Dashboard -> Products -> Pro -> Price ID
STRIPE_TEAM_PRICE_ID=   # Created by scripts/setup-stripe.ts or from Stripe Dashboard -> Products -> Team -> Price ID

# X Ads Conversion API (optional — server-side subscription purchase attribution)
X_ADS_API_KEY=
X_ADS_API_SECRET=
X_ADS_ACCESS_TOKEN=
X_ADS_ACCESS_TOKEN_SECRET=
X_ADS_PIXEL_ID=
X_ADS_PURCHASE_EVENT_ID=

# Resend (email)
RESEND_API_KEY=

# Cron jobs (Coolify cron container or external scheduler — NOT Vercel)
CRON_SECRET=          # Secret used to authenticate cron job requests (generate with: openssl rand -hex 32)

# QStash (Upstash webhook delivery)
QSTASH_TOKEN=         # Upstash Console > QStash > API Keys
QSTASH_CURRENT_SIGNING_KEY=  # Upstash Console > QStash > Signing Keys
QSTASH_NEXT_SIGNING_KEY=     # Upstash Console > QStash > Signing Keys

# Sentry
SENTRY_DSN=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_DOCS_URL=http://localhost:3003
