{
  "name": "@uploadkitdev/next",
  "version": "0.2.1",
  "description": "UploadKit Next.js server integration — createUploadKitHandler, file router, presigned URL generation, and Express/Fastify/Hono adapters.",
  "license": "MIT",
  "author": "Drumst0ck",
  "homepage": "https://uploadkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drumst0ck/uploadkit.git",
    "directory": "packages/next"
  },
  "bugs": {
    "url": "https://github.com/drumst0ck/uploadkit/issues"
  },
  "keywords": [
    "upload",
    "file-upload",
    "nextjs",
    "uploadkit",
    "s3",
    "r2",
    "presigned-url",
    "file-router",
    "typescript"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr-plugin.d.ts",
      "import": "./dist/ssr-plugin.mjs",
      "require": "./dist/ssr-plugin.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.mjs",
      "require": "./dist/adapters/express.js"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "import": "./dist/adapters/fastify.mjs",
      "require": "./dist/adapters/fastify.js"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.mjs",
      "require": "./dist/adapters/hono.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@uploadkitdev/core": "workspace:*",
    "@aws-sdk/client-s3": "latest",
    "@aws-sdk/s3-request-presigner": "latest",
    "nanoid": "latest"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/react": "latest",
    "@uploadkitdev/config": "workspace:*",
    "@uploadkitdev/shared": "workspace:*",
    "fastify": "latest",
    "hono": "latest",
    "tsup": "latest",
    "typescript": "latest"
  }
}
